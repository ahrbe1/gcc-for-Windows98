From: gcc-for-windows98 patcher <patches@example.invalid>
Subject: [PATCH] winansi: fix vsnprintf length-probe for Win9x msvcrt

Win98 SE msvcrt's _vsnprintf does not support the (NULL, 0) length
probe -- it returns -1 instead of the would-be-written length (which
is a Windows 7+ extension).  busybox-w32's winansi_vsnprintf depends
on that probe and on top stores the int return in a size_t, making
its `if (len < 0)` guard unreachable.  Net effect: the function
returns -1, winansi_vfprintf treats that as `buffer too small`,
calls xmalloc(0) + _vsnprintf(buf, 0, ...), still gets -1, and
goto-aborts to the real libc vfprintf -- which writes raw output
to the FILE* WITHOUT going through ansi_emulate.  That's why on
Win98 SE typing Backspace in sh prints `<-[1D` and `ls --color`
emits raw color codes despite patch 0005 forcing terminal_mode=0.
Round 5 BBLOG.TXT (consdiag/run_5) is the proof: every
winansi_vfprintf-entry log for a format string carrying \e[...
has NO follow-up winansi_vfprintf-rendered / ansi_emulate log.
Plain-text writes via winansi_fputs (no vsnprintf in the path)
always reach ansi_emulate and render correctly.

Replace winansi_vsnprintf with an implementation that doesn't need
the (NULL, 0) probe: try the caller's buffer first; on truncation,
grow a scratch buffer until _vsnprintf fits.  Also harden
winansi_vfprintf to bail on -1 BEFORE the size_t comparison that
would otherwise wrap -1 to SIZE_MAX and enter the broken malloc
path.  Both edits live in win32/winansi.c.

---
diff --git a/win32/winansi.c b/win32/winansi.c
--- a/win32/winansi.c
+++ b/win32/winansi.c
@@ -1065,18 +1065,52 @@
 int FAST_FUNC
 winansi_vsnprintf(char *buf, size_t size, const char *format, va_list list)
 {
-	size_t len;
+	/* Original code probed length with _vsnprintf(NULL, 0, ...) -- a
+	 * Windows 7+ msvcrt extension that returns -1 on Win98 SE msvcrt.
+	 * That cascaded into winansi_vfprintf's `goto abort` path (since
+	 * the original assigned _vsnprintf's int return into a size_t,
+	 * making the `if (len < 0)` guard unreachable but still surfacing
+	 * SIZE_MAX -> -1 to the caller), causing backspace + ls --color
+	 * raw escapes on Win98.  Strategy: try the caller's buffer first;
+	 * on truncation, grow a scratch buffer until _vsnprintf fits and
+	 * return the true length.  Patch 0010 (round 5 BBLOG.TXT proof). */
 	va_list list2;
-
-	va_copy(list2, list);
-	len = _vsnprintf(NULL, 0, format, list2);
-	va_end(list2);
-	if (len < 0)
-		return -1;
-
-	_vsnprintf(buf, size, format, list);
-	buf[size-1] = '\0';
-	return len;
+	int len = -1;
+	size_t probe;
+	char *scratch;
+
+	if (buf != NULL && size > 0) {
+		va_copy(list2, list);
+		len = _vsnprintf(buf, size, format, list2);
+		va_end(list2);
+		buf[size - 1] = '\0';
+		if (len >= 0 && (size_t)len < size)
+			return len;
+	}
+
+	probe = (size > 256) ? size * 2 : 512;
+	for (;;) {
+		scratch = malloc(probe);
+		if (scratch == NULL)
+			return -1;
+		va_copy(list2, list);
+		len = _vsnprintf(scratch, probe, format, list2);
+		va_end(list2);
+		if (len >= 0 && (size_t)len < probe) {
+			if (buf != NULL && size > 0) {
+				size_t copy;
+				copy = ((size_t)len < size - 1) ? (size_t)len : size - 1;
+				memcpy(buf, scratch, copy);
+				buf[copy] = '\0';
+			}
+			free(scratch);
+			return len;
+		}
+		free(scratch);
+		probe *= 2;
+		if (probe > 16u * 1024u * 1024u)
+			return -1;
+	}
 }
 #endif
 
@@ -1097,6 +1131,9 @@
 	len = vsnprintf(small_buf, sizeof(small_buf), format, cp);
 	va_end(cp);
 
+	if (len == -1)
+		goto abort;
+
 	if (len > sizeof(small_buf) - 1) {
 		buf = xmalloc(len + 1);
 		va_copy(cp, list);
